{
	"compilerOptions": {
		"target": "es6",
		"lib": ["dom", "dom.iterable", "esnext", "es6"],
		"outDir": "./build/",
		"noImplicitAny": true,
		"module": "esnext",
		"baseUrl": "src",
		"allowJs": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dev-server", "server", "styleguide"]
}
