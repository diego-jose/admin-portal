{
	"name": "admin-portal",
	"version": "0.1.0",
	"private": true,
	"dependencies": {
		"@types/enzyme": "^3.10.3",
		"@types/jest": "^24.0.18",
		"@types/node": "12.7.3",
		"@types/react": "16.9.2",
		"@types/react-dom": "16.9.0",
		"@types/yup": "0.26.23",
		"antd": "3.23.1",
		"cross-env": "5.2.1",
		"cypress": "3.4.1",
		"eslint": "6.4.0",
		"eslint-config-airbnb": "18.0.1",
		"eslint-config-prettier": "2.9.0",
		"eslint-loader": "2.2.1",
		"eslint-plugin-chai-friendly": "0.4.1",
		"eslint-plugin-import": "2.18.2",
		"eslint-plugin-jsx-a11y": "6.2.3",
		"eslint-plugin-prettier": "2.6.2",
		"eslint-plugin-react": "7.14.3",
		"eslint-plugin-react-hooks": "1.7.0",
		"flush-promises": "1.0.2",
		"formik": "1.5.8",
		"husky": "3.0.5",
		"lodash": "4.17.15",
		"node-sass": "4.12.0",
		"nodemon": "1.18.6",
		"prettier": "1.14.2",
		"react": "16.9.0",
		"react-dom": "16.9.0",
		"react-router-dom": "5.0.1",
		"react-scripts": "3.1.1",
		"superagent": "5.1.0",
		"ts-jest": "^24.1.0",
		"tslint": "5.19.0",
		"tslint-config-prettier": "1.14.0",
		"tslint-eslint-rules": "5.4.0",
		"tslint-react": "3.6.0",
		"typescript": "3.5.3",
		"yup": "0.27.0"
	},
	"devDependencies": {
		"@types/react-router-dom": "^4.3.5",
		"enzyme": "3.10.0",
		"enzyme-adapter-react-16": "1.14.0",
		"jest": "24.8.0",
		"jest-junit": "8.0.0",
		"jest-sonar-reporter": "2.0.0"
	},
	"scripts": {
		"start": "react-scripts start",
		"build": "react-scripts build",
		"test": "jest test --verbose --watch",
		"coverage": "jest test --verbose --coverage",
		"eject": "react-scripts eject"
	},
	"jest-junit": {
		"suiteName": "jest tests",
		"output": "./coverage/junit.xml",
		"classNameTemplate": "{classname} - {title}",
		"titleTemplate": "{classname} - {title}",
		"ancestorSeparator": " > ",
		"usePathForSuiteName": "true"
	},
	"jestSonar": {
		"reportPath": "coverage",
		"reportFile": "jest-sonar-reporter.xml",
		"indent": 4
	},
	"jest": {
		"reporters": [
			"default",
			"jest-junit"
		],
		"testResultsProcessor": "jest-sonar-reporter",
		"coverageReporters": [
			"cobertura",
			"html",
			"lcov",
			"text-summary",
			"text"
		],
		"coverageThreshold": {
			"global": {
				"branches": 100,
				"lines": 100,
				"functions": 100,
				"statements": 100
			}
		},
		"collectCoverageFrom": [
			"src/**/*.{js,jsx,tsx,ts}",
			"!src/index.tsx"
		],
		"roots": [
			"<rootDir>/src"
		],
		"setupFilesAfterEnv": [
			"<rootDir>/src/config/setupTests.js"
		],
		"testEnvironment": "jsdom",
		"testURL": "http://localhost",
		"transform": {
			"^.+\\.tsx?$": "ts-jest",
			"^.+\\.(js|jsx)$": "<rootDir>node_modules/babel-jest",
			"^.+\\.css$": "<rootDir>node_modules/react-scripts/config/jest/cssTransform.js",
			"^(?!.*\\.(js|jsx|css|json|tsx|ts)$)": "<rootDir>node_modules/react-scripts/config/jest/fileTransform.js"
		},
		"transformIgnorePatterns": [
			"[/\\\\]node_modules[/\\\\].+\\.(js|jsx|tsx|ts)$"
		],
		"moduleNameMapper": {
			"^react-native$": "react-native-web"
		},
		"moduleFileExtensions": [
			"js",
			"json",
			"jsx",
			"tsx",
			"ts"
		]
	},
	"babel": {
		"presets": [
			"react-app"
		]
	},
	"husky": {
		"hooks": {
			"pre-push": "yarn run coverage"
		}
	},
	"eslintConfig": {
		"extends": "react-app"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
